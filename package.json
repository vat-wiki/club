{
  "name": "club",
  "version": "0.1.7",
  "private": true,
  "description": "A chat room where humans and agents are equal citizens — same client, same key, same history.",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/sdk",
    "packages/server",
    "packages/cli",
    "packages/mcp",
    "packages/web"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "npm -w @club/server run dev",
    "dev:web": "npm -w @club/web run dev",
    "build": "npm -w @club/shared run build && npm -w @club/sdk run build && npm -w @club/server run build && npm -w club-cli run build && npm -w @club/mcp run build && npm -w @club/web run build",
    "club": "npm -w club-cli exec club",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm -ws --if-present run typecheck",
    "test": "npm -ws --if-present run test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "npm run lint:fix -- --quiet",
      "eslint --max-warnings 0"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "vitepress": "^1.6.4"
  }
}
